# Live provider credentials. Keep this file without real secrets in Git.
OPENWEATHER_API_KEY=
OPENAQ_API_KEY=
NASA_FIRMS_MAP_KEY=

# Administrator-only model retraining. Set ONE option in Render Environment.
# Plain secret option (simple):
ADMIN_PASSWORD=
# Or SHA-256 hash option (preferred). Leave ADMIN_PASSWORD empty when using this.
ADMIN_PASSWORD_SHA256=

WEATHER_REFRESH_SECONDS=180
AIR_QUALITY_REFRESH_SECONDS=300
FIRMS_REFRESH_SECONDS=600
FORECAST_REFRESH_SECONDS=1800
BROADCAST_INTERVAL_SECONDS=1
HISTORY_SAMPLE_SECONDS=300
HISTORY_RETENTION_DAYS=90
MODEL_MIN_SAMPLES=24
DATA_DIR=data

GOMBE_LAT=10.2897
GOMBE_LON=11.1673
GOMBE_BBOX=[10.15,9.45,12.35,11.55]
