# The dashboard starts in a fully animated demo mode when keys are absent.
OPENWEATHER_API_KEY=
OPENAQ_API_KEY=
NASA_FIRMS_MAP_KEY=

# Polling intervals. The browser still receives a new interpolated frame every second.
WEATHER_REFRESH_SECONDS=180
AIR_QUALITY_REFRESH_SECONDS=300
FIRMS_REFRESH_SECONDS=600
BROADCAST_INTERVAL_SECONDS=1

# Gombe metropolis reference point and state bounding box.
GOMBE_LAT=10.2897
GOMBE_LON=11.1673

# Preferred JSON-list format. The application also accepts:
# GOMBE_BBOX=10.15,9.45,12.35,11.55
GOMBE_BBOX=[10.15,9.45,12.35,11.55]
